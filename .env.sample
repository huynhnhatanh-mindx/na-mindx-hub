# =========================================================================
#                    CẤU HÌNH HỆ THỐNG CHUNG (DÙNG CHO CẢ LOCAL & PROD)
# =========================================================================
PORT=5000

# Lựa chọn phương thức lưu trữ dự phòng: 'mega', 'google-drive', hoặc 'local'
STORAGE_PROVIDER=google-drive

# Thư mục Google Drive của hệ thống (Service Account)
GOOGLE_DRIVE_FOLDER_ID=YOUR_SYSTEM_GOOGLE_DRIVE_FOLDER_ID

# Cấu hình lưu trữ MEGA
MEGA_EMAIL=YOUR_MEGA_EMAIL
MEGA_PASSWORD=YOUR_MEGA_PASSWORD
MEGA_FOLDER_NAME=NA MindX Hub - Upload

# Cấu hình Cơ sở dữ liệu & Bảo mật
MONGODB_URI=YOUR_MONGODB_ATLAS_CONNECTION_STRING
ADMIN_PASSCODE=YOUR_ADMIN_PASSCODE

# Cấu hình Google Drive OAuth (Bắt buộc để giáo viên liên kết tài khoản)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Cấu hình gửi Email (Nodemailer SMTP - Hỗ trợ Resend, Gmail, Bizfly)
# - Dành cho Resend: HOST=smtp.resend.com, PORT=465, EMAIL=onboarding@resend.dev (hoặc email domain đã verify), PASS=API Key (re_...)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
FEEDBACK_EMAIL=onboarding@resend.dev
FEEDBACK_EMAIL_PASS=re_YOUR_RESEND_API_KEY

# =========================================================================
#                    CẤU HÌNH RIÊNG CHO MÔI TRƯỜNG LOCAL (LOCALHOST)
# =========================================================================
# Các biến dành cho môi trường Local / Development
VITE_API_URL_DEV=http://localhost:5000
GOOGLE_REDIRECT_URI_DEV=http://localhost:5000/api/auth/google/callback
FRONTEND_URL_DEV=http://localhost:5173

# =========================================================================
#                    CẤU HÌNH RIÊNG CHO MÔI TRƯỜNG PRODUCTION (RENDER & VERCEL)
# =========================================================================
# Các biến dành cho môi trường Production khi deploy
VITE_API_URL_PROD=https://YOUR_BACKEND_APP_ON_RENDER.onrender.com
GOOGLE_REDIRECT_URI_PROD=https://YOUR_BACKEND_APP_ON_RENDER.onrender.com/api/auth/google/callback
FRONTEND_URL_PROD=https://YOUR_FRONTEND_APP_ON_VERCEL.vercel.app
