# =========================================================================
#                    CẤU HÌNH CHO MÔI TRƯỜNG LOCAL (LOCALHOST)
# =========================================================================
PORT=5000
NODE_ENV=development

# Lựa chọn phương thức lưu trữ mặc định khi chạy offline hoặc dự phòng: 'google-drive' hoặc 'local'
STORAGE_PROVIDER=local

# Cấu hình Cơ sở dữ liệu & Bảo mật
MONGODB_URI=mongodb://localhost:27017/na-mindx-hub
ADMIN_PASSCODE=admin123
JWT_SECRET=your_jwt_secret_key_here

# Cấu hình Google Drive OAuth (Bắt buộc để giáo viên liên kết tài khoản)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Cấu hình gửi Email (Resend)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
FEEDBACK_EMAIL=onboarding@resend.dev
FEEDBACK_EMAIL_PASS=re_YOUR_RESEND_API_KEY

# URL Frontend
FRONTEND_URL=http://localhost:5173
